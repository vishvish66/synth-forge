APP_NAME="SynthForge Backend"
APP_VERSION="0.1.0"
ENVIRONMENT="dev"

MAX_ROW_COUNT=10000000
DEFAULT_ROW_COUNT=100000
SAMPLE_ROWS_RETURNED=20

UNITY_CATALOG_NAME="main"
UNITY_SCHEMA_NAME="synthforge"
DELTA_BRONZE_PATH="/Volumes/main/synthforge/bronze"
DELTA_SILVER_PATH="/Volumes/main/synthforge/silver"
DELTA_GOLD_PATH="/Volumes/main/synthforge/gold"

DATABRICKS_DBU_RATE_USD=0.55
VM_HOURLY_RATE_USD=1.25
DEFAULT_WORKERS=4
DEFAULT_RUNTIME_HOURS=1.5

FAKER_SEED=42
CORS_ORIGINS="http://localhost:3000,http://127.0.0.1:3000"
ARTIFACT_TTL_MINUTES=60
